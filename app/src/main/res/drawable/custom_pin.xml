<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <size
                android:width="20dp"
                android:height="20dp" />
            <stroke
                android:width="1dp"
                android:color="#40000000" />
        </shape>
    </item>

    <item
        android:width="15dp"
        android:height="15dp"
        android:gravity="center"
        android:drawable="@drawable/pushpin" />

</layer-list>