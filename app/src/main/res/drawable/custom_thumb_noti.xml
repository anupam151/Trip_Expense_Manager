<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Your existing circular thumb -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <size
                android:width="28dp"
                android:height="28dp" />
            <stroke
                android:width="1dp"
                android:color="#40000000" /> <!-- Subtle border for depth -->
        </shape>
    </item>

    <!-- 2. The fingerprint icon, restricted in size and perfectly centered -->
    <item
        android:width="15dp"
        android:height="15dp"
        android:gravity="center"
        android:drawable="@drawable/notification" />

</layer-list>