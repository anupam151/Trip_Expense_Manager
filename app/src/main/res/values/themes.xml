<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Base.Theme.TripExpenseManager" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorControlActivated">#000000</item>
        <item name="colorControlNormal">#808080</item>
        <item name="android:textColorHighlight">#CCCCCC</item>

        <item name="checkboxStyle">@style/CustomCheckboxStyle</item>
        <item name="android:datePickerDialogTheme">@style/CustomCalendarTheme</item>
        <item name="android:alertDialogTheme">@style/CustomAlertDialogTheme</item>

        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="android:dropDownListViewStyle">@style/CustomDropDownListView</item>
        <item name="android:spinnerDropDownItemStyle">@style/CustomSpinnerDropDownItem</item>
    </style>

    <style name="Theme.TripExpenseManager" parent="Base.Theme.TripExpenseManager" />

    <style name="CustomCheckboxStyle" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/checkbox_state_colors</item>
        <item name="android:backgroundTint">#FFFFFF</item>
    </style>

    <style name="CustomDropDownListView" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:background">#FFFFFF</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="CustomSpinnerDropDownItem" parent="Widget.AppCompat.DropDownItem.Spinner">
        <item name="android:textColor">#000000</item>
        <item name="android:background">#FFFFFF</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="android:background">#FFFFFF</item>
        <item name="colorPrimary">#85022E</item>
        <item name="colorAccent">#85022E</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#424242</item>
        <item name="buttonBarPositiveButtonStyle">@style/AlertDialogButtonBoldBlack</item>
        <item name="buttonBarNegativeButtonStyle">@style/AlertDialogButtonBoldBlack</item>
    </style>

    <style name="AlertDialogButtonBoldBlack" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">#000000</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CustomCalendarTheme" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">#85022E</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorAccent">#85022E</item>
        <item name="buttonBarPositiveButtonStyle">@style/CalendarWhiteTextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/CalendarWhiteTextButton</item>
    </style>

    <style name="CalendarWhiteTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>