<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    xmlns:tools2="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UtilityActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F6F8">

        <!-- TOP APP BAR -->
        <RelativeLayout
            android:id="@+id/top_app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingBottom="6dp"
            android:paddingTop="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/app_name"
                android:fontFamily="monospace"
                android:textColor="#85022E"
                android:textSize="15sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- SCREEN HEADER -->
        <LinearLayout
            android:id="@+id/tools_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/top_app_bar"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/btn_open_drawer"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/menu"
                android:tint="#85022E"
                tools:ignore="UseAppTint"
                android:contentDescription="Open Menu"
                tools2:ignore="UseAppTint" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:text="Tools &amp; Utility"
                android:textColor="#85022E"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SCROLLABLE UTILITY CARDS -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/button_container"
            android:layout_below="@id/tools_header"
            android:clipToPadding="false"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quick features and reports for your active trips."
                    android:textColor="#3A4664"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="16dp"/>

                <!-- TOOL 1: Quick Bill Splitter -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tool_bill_splitter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="🍕  Quick Bill Splitter"
                        android:textColor="#0D1A39"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- TOOL 2: All-Time Statistics -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tool_statistics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="📊  All-Time Statistics"
                        android:textColor="#0D1A39"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- TOOL 3: Reports Vault -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tool_reports_vault"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="📁  Reports Vault (PDFs &amp; CSVs)"
                        android:textColor="#0D1A39"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- TOOL 4: Live Currency Converter -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tool_currency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="💱  Live Currency Converter"
                        android:textColor="#0D1A39"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- TOOL 5: Travel Checklist -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tool_checklist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="🎒  Travel Checklist"
                        android:textColor="#0D1A39"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- TOOL 6: Fuel Calculator -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tool_fuel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="⛽  Road Trip Fuel Calculator"
                        android:textColor="#0D1A39"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <!-- TOOL 7: Archived Trips -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tool_archived"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="30dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="📦  Archived Trips"
                        android:textColor="#0D1A39"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- EXACT REPLICA OF YOUR BOTTOM NAVIGATION -->
        <LinearLayout
            android:id="@+id/button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="#E9E9E9"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:layout_marginHorizontal="12dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/btn_dash_utility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_add_expense"
                        android:tint="#85022E"
                        tools:ignore="UseAppTint"
                        android:contentDescription="@string/dash_btn_utility"
                        tools2:ignore="UseAppTint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_utility"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_dash_create_trip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/create_trip"
                        android:tint="#85022E"
                        tools:ignore="UseAppTint"
                        android:contentDescription="@string/dash_btn_create_trip"
                        tools2:ignore="UseAppTint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_create_trip"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_dash_view_trips"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/trip"
                        android:tint="#85022E"
                        android:contentDescription="@string/dash_btn_view_trip"
                        tools2:ignore="UseAppTint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_view_trip"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_dash_settings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/settings"
                        android:tint="#85022E"
                        tools:ignore="UseAppTint"
                        android:contentDescription="@string/dash_btn_settings"
                        tools2:ignore="UseAppTint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_settings"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/txt_dash_developer_branding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#3A4664"
                android:textSize="14sp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                tools:text="Designed and Developed by Anupam" />
        </LinearLayout>

    </RelativeLayout>

    <include layout="@layout/layout_universal_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>