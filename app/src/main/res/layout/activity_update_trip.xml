<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    tools:context=".UpdateTripActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_view_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="82dp"
        android:layout_marginBottom="90dp"
        android:layout_marginHorizontal="6dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#FFFFFF">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_name_of_trip"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/globe"
                            android:contentDescription="@string/desc_trip_icon"
                            app:tint="#85022E" />
                    </LinearLayout>
                    <EditText
                        android:id="@+id/edt_update_trip_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="@string/hint_enter_trip_name"
                        android:inputType="textCapWords"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_trip_destination"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/location"
                            android:contentDescription="@string/desc_destination_icon"
                            app:tint="#85022E" />
                    </LinearLayout>
                    <EditText
                        android:id="@+id/edt_update_destination"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="@string/hint_enter_destination"
                        android:inputType="textCapWords"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_journey_start_date"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/edit_calendar"
                            android:contentDescription="@string/desc_calendar_icon"
                            app:tint="#85022E" />
                    </LinearLayout>
                    <EditText
                        android:id="@+id/edt_update_start_date"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:focusable="false"
                        android:hint="@string/hint_select_date"
                        android:inputType="date"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_journey_end_date"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/edit_calendar"
                            android:contentDescription="@string/desc_calendar_icon"
                            app:tint="#85022E" />
                    </LinearLayout>
                    <EditText
                        android:id="@+id/edt_update_end_date"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:focusable="false"
                        android:hint="@string/hint_select_date"
                        android:inputType="date"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/label_add_trip_members"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashed_box"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView
                        android:id="@+id/txt_update_no_members"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_no_members_yet"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txt_update_members_subtext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/txt_add_members_subtext"
                        android:textColor="#838383"
                        android:textSize="13sp" />
                    <Button
                        android:id="@+id/btn_update_member_trigger"
                        android:layout_width="160dp"
                        android:layout_height="45dp"
                        android:backgroundTint="#CC843D"
                        android:text="@string/btn_add_new_member"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="8dp" />
                    <LinearLayout
                        android:id="@+id/layout_update_member_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:visibility="visible"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="4dp"
        android:paddingTop="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:fontFamily="monospace"
            android:textColor="#85022E"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="#85022E"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/arrow_back"
            android:contentDescription="@string/desc_back_button"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/title_update_trip"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:background="#F5F6F8"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_trip_submit"
            app:icon="@drawable/amend"
            android:text="@string/btn_update_trip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#85022E"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="14dp"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="8dp"
            app:iconGravity="textStart"
            android:textColor="#FFFFFF"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:layout_marginBottom="10dp"
            android:fontFamily="monospace"
            android:textColor="#85022E"
            android:textSize="12sp" />
    </LinearLayout>
</RelativeLayout>