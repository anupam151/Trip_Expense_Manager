<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    tools:context=".UpdateTripActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_columnWeight="1"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#85022E">
            <LinearLayout
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/btn_update_trip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_trip_name"
            android:textColor="#0D1A39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/edt_update_trip_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/hint_trip_name"
            android:textColorHint="#838383"
            android:inputType="textCapWords"
            android:autofillHints="none"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_marginBottom="16dp"
            android:textColor="#000000"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_destination"
            android:textColor="#0D1A39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/edt_update_destination"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/hint_destination"
            android:textColorHint="#838383"
            android:inputType="textCapWords"
            android:autofillHints="none"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_marginBottom="16dp"
            android:textColor="#000000"
            android:textSize="16sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_start_date"
            android:textColor="#0D1A39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/edt_update_start_date"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/hint_date_picker"
            android:textColorHint="#838383"
            android:inputType="date"
            android:autofillHints="none"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:longClickable="false"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_marginBottom="16dp"
            android:textColor="#000000"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_end_date"
            android:textColor="#0D1A39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/edt_update_end_date"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/hint_date_picker"
            android:textColorHint="#838383"
            android:inputType="date"
            android:autofillHints="none"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:longClickable="false"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="#000000"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_add_members"
            android:textColor="#0D1A39"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_update_member_trigger"
            android:layout_width="180dp"
            android:layout_height="50dp"
            android:text="@string/btn_add_member_trigger"
            android:textColor="#FFFFFF"
            android:backgroundTint="#CC843D"
            app:cornerRadius="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            tools:ignore="AccessibilityContrastCheck" />

        <LinearLayout
            android:id="@+id/layout_update_member_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"/>

        <Button
            android:id="@+id/btn_update_trip_submit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_update_trip"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#85022E"
            app:cornerRadius="8dp"
            tools:ignore="AccessibilityContrastCheck" />

    </LinearLayout>
</ScrollView>