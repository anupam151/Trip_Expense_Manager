<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6F8"
    tools:context=".UpdateTripActivity">

    <!-- Sticky Header Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="#85022E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingTop="4dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/arrow_back"
            android:contentDescription="@string/desc_back_button"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/btn_update_trip"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <!-- Main White Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:cardCornerRadius="16dp"
                android:padding="20dp">

                <!-- TRIP NAME -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_name_of_trip"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">

                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/globe"
                            android:contentDescription="@string/desc_trip_icon"
                            app:tint="#85022E" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edt_update_trip_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="@string/hint_enter_trip_name"
                        android:inputType="textCapWords"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- DESTINATION -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_trip_destination"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">

                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/location"
                            android:contentDescription="@string/desc_destination_icon"
                            app:tint="#85022E" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edt_update_destination"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="@string/hint_enter_destination"
                        android:inputType="textCapWords"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- START DATE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_journey_start_date"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">

                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/edit_calendar"
                            android:contentDescription="@string/desc_calendar_icon"
                            app:tint="#85022E" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edt_update_start_date"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:focusable="false"
                        android:hint="@string/hint_select_date"
                        android:inputType="date"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />

                </LinearLayout>

                <!-- END DATE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_journey_end_date"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:padding="6dp">

                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/edit_calendar"
                            android:contentDescription="@string/desc_calendar_icon"
                            app:tint="#85022E" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edt_update_end_date"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:focusable="false"
                        android:hint="@string/hint_select_date"
                        android:inputType="date"
                        android:autofillHints="none"
                        android:textColor="#000000"
                        android:textColorHint="#A0A0A0"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- ADD MEMBERS SECTION -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/label_add_trip_members"
                    android:textColor="#0D1A39"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Dashed Box Container -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashed_box"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:layout_marginBottom="24dp">

                    <!-- Added ID for empty state text so it can be toggled in Java -->
                    <TextView
                        android:id="@+id/txt_update_no_members"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_no_members_yet"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Added ID for empty state subtext -->
                    <TextView
                        android:id="@+id/txt_update_members_subtext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/txt_add_members_subtext"
                        android:textColor="#838383"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_update_member_trigger"
                        android:layout_width="160dp"
                        android:layout_height="45dp"
                        android:backgroundTint="#DE7C26"
                        android:text="@string/btn_add_new_member"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="8dp" />

                    <LinearLayout
                        android:id="@+id/layout_update_member_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:visibility="visible"/>
                </LinearLayout>

                <!-- SUBMIT BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_update_trip_submit"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="#85022E"
                    android:text="@string/btn_update_trip"
                    android:textAllCaps="false"
                    android:textSize="22sp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/flight"
                    app:iconGravity="textStart"
                    app:iconTint="#FFFFFF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>
</LinearLayout>