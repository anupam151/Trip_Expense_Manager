<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#F5F6F8"
    android:descendantFocusability="blocksDescendants">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp">
            <TextView
                android:id="@+id/txt_item_trip_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/layout_item_actions"
                android:textColor="#0D1A39"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="1. Kolkata Tour" />
            <LinearLayout
                android:id="@+id/layout_item_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#CCCCCC" />
                <TextView
                    android:id="@+id/btn_item_pin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_state_pin"
                    android:textColor="#C85A00"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    tools:ignore="TouchTargetSizeCheck" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#CCCCCC" />
                <TextView
                    android:id="@+id/btn_item_edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_edit"
                    android:textColor="#1A73E8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    tools:ignore="TouchTargetSizeCheck" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#CCCCCC" />
                <TextView
                    android:id="@+id/btn_item_delete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_delete"
                    android:textColor="#D93025"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    tools:ignore="TouchTargetSizeCheck" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#CCCCCC" />
            </LinearLayout>
        </RelativeLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingEnd="1dp">
                <TextView
                    android:id="@+id/txt_item_destination"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#3A4154"
                    android:textSize="15sp"
                    android:layout_marginBottom="5dp"
                    tools:text="Destination: Victoria Memorial" />
                <TextView
                    android:id="@+id/txt_item_member_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#3A4154"
                    android:textSize="15sp"
                    android:layout_marginBottom="5dp"
                    tools:text="No. of Members: 5" />
                <TextView
                    android:id="@+id/txt_item_start_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#3A4154"
                    android:textSize="15sp"
                    tools:text="Start Date: 22/06/2026"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/label_fund_balance"
                    android:textColor="#5A6684"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txt_item_fund_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2E7D32"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp"
                    tools:text="₹0.00" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="0dp"
                tools:ignore="RtlSymmetry">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_expense"
                    android:textColor="#5A6684"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txt_item_total_expense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#D93025"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"
                    tools:text="₹0.00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_received"
                    android:textColor="#5A6684"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txt_item_total_received"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2E7D32"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="₹0.00" />
            </LinearLayout>
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_item_add_expense"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_add_expense"
                android:textColor="#85022E"
                app:strokeWidth="1dp"
                app:strokeColor="#85022E"
                android:textSize="14sp"
                android:backgroundTint="#FFFFFF"
                app:cornerRadius="8dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_item_add_payment"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:textStyle="bold"
                android:text="@string/btn_add_payment"
                app:strokeWidth="1dp"
                app:strokeColor="#0A590F"
                android:textColor="#0A590F"
                android:textSize="14sp"
                android:backgroundTint="#FFFFFF"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>