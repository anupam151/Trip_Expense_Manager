<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Serial Number (Sl No) -->
        <TextView
            android:id="@+id/txt_archived_sl_no"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="#E9E9E9"
            android:gravity="center"
            android:text="1"
            android:textColor="#85022E"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Trip Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_archived_destination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Darjeeling"
                android:textColor="#000000"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_archived_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Departure: 14 Aug 2026"
                android:textColor="#757575"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txt_archived_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Total Expense: ₹12,500"
                android:textColor="#85022E"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Your MaterialButton for Unarchiving -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unarchive_trip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unarchive"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            app:cornerRadius="6dp"
            android:layout_gravity="end|center_vertical"
            app:backgroundTint="#2E7D32" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>