<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    xmlns:tools2="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CurrencyConverterActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F6F8">

        <!-- TOP APP BAR -->
        <RelativeLayout
            android:id="@+id/top_app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingBottom="6dp"
            android:paddingTop="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/app_name"
                android:fontFamily="monospace"
                android:textColor="#85022E"
                android:textSize="15sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- SCREEN HEADER -->
        <LinearLayout
            android:id="@+id/tools_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/top_app_bar"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/btn_open_drawer"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/menu"
                android:tint="#85022E"
                tools:ignore="UseAppTint"
                android:contentDescription="Open Menu"
                tools2:ignore="UseAppTint" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:text="Currency Converter"
                android:textColor="#85022E"
                android:textSize="23sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SCROLLABLE CONVERTER AREA -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/button_container"
            android:layout_below="@id/tools_header"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- CONVERTER CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp">

                        <!-- CURRENCY SELECTION ROW -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="bottom"> <!-- Changed to bottom to align Spinners and icon perfectly -->

                            <!-- FROM CURRENCY -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="From"
                                    android:textColor="#3A4664"
                                    android:textSize="14sp"/>
                                <Spinner
                                    android:id="@+id/spinner_from"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_marginTop="4dp"
                                    android:background="@drawable/bg_rounded_dialog_spinner" />
                            </LinearLayout>

                            <!-- SWAP ICON -->
                            <ImageView
                                android:id="@+id/btn_swap"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginHorizontal="12dp"
                                android:layout_marginBottom="8dp"
                                android:src="@drawable/swap"
                                app:tint="#85022E" />

                            <!-- TO CURRENCY -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="To"
                                    android:textColor="#3A4664"
                                    android:textSize="14sp"/>
                                <Spinner
                                    android:id="@+id/spinner_to"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_marginTop="4dp"
                                    android:background="@drawable/bg_rounded_dialog_spinner" />
                            </LinearLayout>

                        </LinearLayout>



                        <EditText
                            android:id="@+id/edit_amount"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:gravity="center"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_rounded_dialog_spinner"
                            android:paddingHorizontal="16dp"
                            android:inputType="numberDecimal"
                            android:hint="Enter amount"
                            android:textColor="#000000"
                            android:textColorHint="#999999"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/txt_conversion_result"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00"
                                android:textColor="#85022E"
                                android:textSize="36sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txt_exchange_rate_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Enter amount to convert"
                                android:gravity="center"
                                android:textColor="#5A6684"
                                android:textSize="14sp" />
                        </LinearLayout>


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- BOTTOM NAVIGATION -->
        <LinearLayout
            android:id="@+id/button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="#E9E9E9"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:layout_marginHorizontal="12dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/btn_home_utility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_home"
                        android:tint="#85022E"
                        tools:ignore="UseAppTint"
                        android:contentDescription="@string/home"
                        tools2:ignore="UseAppTint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/home"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_view_trips_utility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/trip"
                        android:tint="#85022E"
                        android:contentDescription="@string/dash_btn_view_trip"
                        tools2:ignore="UseAppTint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_view_trip"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />

                <LinearLayout
                    android:id="@+id/btn_dash_utility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_add_expense"
                        app:tint="#85022E"
                        android:contentDescription="@string/dash_btn_utility"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_utility"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_settings_utility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/settings"
                        android:tint="#85022E"
                        tools:ignore="UseAppTint"
                        android:contentDescription="@string/dash_btn_settings"
                        tools2:ignore="UseAppTint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_settings"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/txt_dash_developer_branding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#3A4664"
                android:textSize="14sp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                tools:text="Designed and Developed by Anupam" />
        </LinearLayout>

    </RelativeLayout>

    <!-- UNIVERSAL DRAWER -->
    <include layout="@layout/layout_universal_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>