<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    tools:context=".DashboardActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="4dp"
        android:paddingTop="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:fontFamily="monospace"
            android:textColor="#85022E"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="35dp"
        android:layout_marginBottom="110dp"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/welcome_message"
            android:textColor="#0D1A39"
            android:textSize="20sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="6dp"
            android:gravity="center"
            android:text="@string/dash_app_title"
            android:textColor="#85022E"
            android:textSize="35sp"
            android:textStyle="bold" />
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="6dp">
                <TextView
                    android:id="@+id/lbl_recent_trip_heading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_pinned_activity_workspace"
                    android:textColor="#0D1A39"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone"
                    tools:visibility="visible" />
                <LinearLayout
                    android:id="@+id/container_pinned_trips_stack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="0dp"
                    android:clipToPadding="false"
                    android:clipChildren="false" />
                <LinearLayout
                    android:id="@+id/layout_no_pinned_trips"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_dashed_box"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="20dp"
                    android:visibility="gone">
                    <!--android:visibility="gone"-->
                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginTop="40dp"
                        android:src="@drawable/pin"
                        android:contentDescription="@string/no_pinned_trips_icon_desc" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_pinned_trips_title"
                        android:textColor="#85022E"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="24dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_pinned_trips_description"
                        android:gravity="center"
                        android:layout_marginTop="20dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_create_new_trips"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/title_create_trip"
                            android:textColor="#85022E"
                            android:textSize="16sp"
                            app:elevation="5dp"
                            android:backgroundTint="#FFFFFF"
                            app:strokeColor="#85022E"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F5F6F8"
        android:gravity="center"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="15dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dash_create_trip"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/dash_btn_create_trip"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#85022E"
                app:cornerRadius="10dp"
                android:layout_weight="1"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dash_view_trips"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/dash_btn_view_trip"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#CC843D"
                app:cornerRadius="10dp"
                android:layout_weight="1"/>
        </LinearLayout>
        <TextView
            android:id="@+id/txt_dash_developer_branding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#3A4664"
            android:textSize="14sp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            tools:text="Designed and Developed by Anupam" />
    </LinearLayout>

</RelativeLayout>