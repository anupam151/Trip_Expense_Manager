<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DashboardActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F6F8">

        <RelativeLayout
            android:id="@+id/top_app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingBottom="6dp"
            android:paddingTop="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/app_name"
                android:fontFamily="monospace"
                android:textColor="#85022E"
                android:textSize="15sp"
                android:textStyle="bold" />
        </RelativeLayout>
        <LinearLayout
            android:id="@+id/dashboard_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/top_app_bar"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/btn_open_drawer"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/menu"
                app:tint="#85022E"
                android:contentDescription="@string/desc_open_menu"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:gravity="center_vertical"
                android:text="@string/dash_app_title"
                android:textColor="#85022E"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/container_dashboard_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/card_workspace"
            android:layout_below="@id/dashboard_header"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:src="@drawable/app_logo"
                android:contentDescription="@string/desc_app_logo" />

        </LinearLayout>
        <androidx.cardview.widget.CardView
            android:id="@+id/card_workspace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/button_container"
            android:layout_alignParentBottom="false"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="6dp">
                <TextView
                    android:id="@+id/lbl_recent_trip_heading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_pinned_activity_workspace"
                    android:textColor="#0D1A39"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone"
                    android:gravity="center"
                    tools:visibility="visible" />
                <LinearLayout
                    android:id="@+id/container_pinned_trips_stack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:clipToPadding="false"
                    android:clipChildren="false" />
                <LinearLayout
                    android:id="@+id/layout_no_pinned_trips"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_dashed_box"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="20dp">
                    <ImageView
                        android:layout_width="73dp"
                        android:layout_height="73dp"
                        android:layout_marginTop="10dp"
                        android:src="@drawable/pin2"
                        android:contentDescription="@string/no_pinned_trips_icon_desc" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_pinned_trips_title"
                        android:textColor="#85022E"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="20dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_pinned_trips_description"
                        android:gravity="center"
                        android:layout_marginTop="10dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_create_new_trips"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/title_create_trip"
                            android:textColor="#85022E"
                            android:textSize="16sp"
                            app:elevation="5dp"
                            android:backgroundTint="#FFFFFF"
                            app:strokeColor="#85022E"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:id="@+id/button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="#E9E9E9"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:layout_marginHorizontal="12dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/btn_dash_extra"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_add_expense"
                        app:tint="#85022E"
                        android:contentDescription="@string/dash_btn_extra"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_extra"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_dash_create_trip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/create_trip"
                        app:tint="#85022E"
                        android:contentDescription="@string/dash_btn_create_trip"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_create_trip"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_dash_view_trips"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/trip"
                        app:tint="#85022E"
                        android:contentDescription="@string/dash_btn_view_trip"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_view_trip"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_vertical"
                    android:background="#CCCCCC" />
                <LinearLayout
                    android:id="@+id/btn_dash_settings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/settings"
                        app:tint="#85022E"
                        android:contentDescription="@string/dash_btn_settings"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="@string/dash_btn_settings"
                        android:textSize="10sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/txt_dash_developer_branding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#3A4664"
                android:textSize="14sp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                tools:text="Designed and Developed by Anupam" />
        </LinearLayout>
    </RelativeLayout>

    <!-- The Drawer Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:orientation="vertical">

        <!-- 1. Your existing Navigation View (Takes up all available space) -->
        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navigation_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:headerLayout="@layout/nav_header"
            app:menu="@menu/drawer_menu" />

        <!-- 2. The Sticky Bottom TextView -->
        <TextView
            android:id="@+id/txt_sticky_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:gravity="center"
            android:paddingBottom="16dp"
            android:text="Version 3.0\nDesigned &amp; Developed by Anupam"
            android:textColor="#85022E"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>