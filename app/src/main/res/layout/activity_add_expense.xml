<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    tools:context=".AddExpenseActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_columnWeight="1"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#85022E">
            <LinearLayout
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/title_add_expense"
                    android:id="@+id/txt_expense_heading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_expense_purpose"
            android:textColor="#0D1A39"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edt_expense_purpose"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:hint="@string/hint_expense_purpose"
            android:inputType="textCapSentences"
            android:paddingHorizontal="10dp"
            android:textColor="#000000"
            android:textColorHint="#5B5B5B"
            android:textSize="15sp"
            android:autofillHints="none"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_amount"
            android:textColor="#0D1A39"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edt_expense_amount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:hint="@string/hint_amount"
            android:inputType="numberDecimal"
            android:paddingHorizontal="10dp"
            android:textColor="#000000"
            android:textColorHint="#5B5B5B"
            android:textSize="15sp"
            android:autofillHints="none"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_expense_date"
            android:textColor="#0D1A39"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_expense_date"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:cursorVisible="false"
            android:longClickable="false"
            android:autofillHints="none"
            android:inputType="date"
            android:hint="@string/hint_date_picker"
            android:paddingHorizontal="10dp"
            android:textColor="#000000"
            android:textColorHint="#5B5B5B"
            android:textSize="15sp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_paid_by"
            android:textColor="#0D1A39"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_paid_by"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/btn_dropdown"
            android:layout_marginBottom="24dp"
            tools:ignore="SpeakableTextPresentCheck" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_expense_for"
            android:textColor="#0D1A39"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_expense_split"
            android:textColor="#5B5B5B"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="12dp" />

        <GridLayout
            android:id="@+id/layout_checkbox_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignBounds"
            android:rowOrderPreserved="false"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_dynamic_members"
                android:textColor="#5B5B5B"
                android:textSize="14sp"
                android:textStyle="italic"
                android:layout_columnSpan="2" />
        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_expense"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/btn_save_expense_split"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#85022E"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>