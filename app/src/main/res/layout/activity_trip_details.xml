<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="78dp"
        android:layout_marginBottom="94dp"
        android:layout_marginHorizontal="6dp"
        android:padding="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_destination"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="1dp"/>
                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:background="#A36324" />
                <TextView
                    android:id="@+id/txt_details_destination"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#85022E"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_journey_date"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="1dp"/>
                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:background="#A36324" />
                <TextView
                    android:id="@+id/txt_details_dates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#85022E"/>
            </LinearLayout>
        </LinearLayout>
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:background="@drawable/bg_dashed_box"
            app:cardBackgroundColor="#FFFFFF"
            android:padding="2dp"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFEAEB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:text="@string/label_members"
                        android:textColor="#000000"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txt_details_member_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#85022E"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FBEDE1">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_fund_balance"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:layout_marginBottom="5dp"/>
                    <TextView
                        android:id="@+id/txt_details_fund_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#A36324"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FBEDE1">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_total_expenses"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:layout_marginBottom="5dp"/>
                    <TextView
                        android:id="@+id/txt_details_total_expenses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#A36324"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFEAEB">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_total_receipts"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:layout_marginBottom="5dp"/>
                    <TextView
                        android:id="@+id/txt_details_total_receipts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#85022E"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </GridLayout>
        <LinearLayout
            android:id="@+id/layoutQuickActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="4"
            android:baselineAligned="false">

            <!-- Add Expense -->

            <LinearLayout
                android:id="@+id/btnAddExpense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_action_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/receipt_long"
                    android:contentDescription="@string/add_expense"
                    app:tint="#CC843D"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="@string/add_expense"
                    android:textColor="#85022E"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

            </LinearLayout>


            <!-- Add Payment -->

            <LinearLayout
                android:id="@+id/btnAddPayment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_action_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/payments"
                    android:contentDescription="@string/add_payment"
                    app:tint="#CC843D"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="@string/add_payment"
                    android:textColor="#85022E"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

            </LinearLayout>


            <!-- Edit Trip -->

            <LinearLayout
                android:id="@+id/btnEditTrip"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_action_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/edit_square"
                    android:contentDescription="@string/edit_trip"
                    app:tint="#CC843D"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="@string/edit_trip"
                    android:textColor="#85022E"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

            </LinearLayout>


            <!-- Delete Trip -->

            <LinearLayout
                android:id="@+id/btnDeleteTrip"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_action_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/delete"
                    android:contentDescription="@string/delete_trip"
                    app:tint="#CC843D" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="@string/delete_trip"
                    android:textColor="#85022E"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_instruction_to_view_member_ledger"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:textColor="#85022E"/>
        </LinearLayout>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FAFAFF"
            android:fillViewport="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_active_members"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp"
                    android:textColor="#85022E"/>

                <GridLayout
                    android:id="@+id/grid_members"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2" />

                <TextView
                    android:id="@+id/txt_inactive_members_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_removed_members"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="2dp"
                    android:textColor="#85022E"
                    android:visibility="gone"/>

                <GridLayout
                    android:id="@+id/grid_inactive_members"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:visibility="gone"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="4dp"
        android:paddingTop="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:fontFamily="monospace"
            android:textColor="#85022E"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="#85022E"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_home"
            android:contentDescription="@string/home"
            android:layout_weight="0.5"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/txt_details_trip_name"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="14dp"
            android:layout_marginVertical="6dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:lines="2"
            android:ellipsize="none"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="8sp"
            app:autoSizeMaxTextSize="30sp"
            app:autoSizeStepGranularity="1sp"
            android:layout_weight="8"/>
        <ImageButton
            android:id="@+id/btn_share_all"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/share"
            android:contentDescription="@string/desc_share_ledger"
            app:tint="#FFFFFF"  />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:background="#F5F6F8"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:orientation="horizontal"
            android:weightSum="2"
            android:background="#F5F6F8"
            android:gravity="center">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_all_individual_to_one_pdf"
                android:layout_width="0dp"
                app:icon="@drawable/pdf"
                android:text="@string/all_in_one_pdf"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#85022E"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                app:iconGravity="textStart"
                android:textColor="#FFFFFF"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_complete_ledger"
                android:layout_width="0dp"
                app:icon="@drawable/bank"
                android:text="@string/complete_ledger"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#85022E"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                app:iconGravity="textStart"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:layout_marginBottom="10dp"
            android:fontFamily="monospace"
            android:textColor="#85022E"
            android:textSize="12sp" />


    </LinearLayout>
</RelativeLayout>