<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://tools.android.com/tools"
    xmlns:tools2="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    tools:context=".TripLedgerActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txt_ledger_trip_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trip_name"
            android:textColor="#0D1A39"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txt_ledger_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trip_destination"
            android:textColor="#4A5568"
            android:textSize="15sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txt_ledger_member_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/number_of_members_0"
            android:textColor="#4A5568"
            android:textSize="15sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txt_ledger_all_members"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/all_member_names"
            android:textColor="#4A5568"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DADCE0"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/txt_ledger_fund_balance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fund Balance: ₹0.00"
            android:textColor="#C85A00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            tools2:ignore="HardcodedText" />

        <TextView
            android:id="@+id/txt_ledger_total_expenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Expenses: ₹0.00"
            android:textColor="#2D3748"
            android:textSize="15sp"
            android:layout_marginBottom="4dp"
            tools2:ignore="HardcodedText" />

        <TextView
            android:id="@+id/txt_ledger_total_payments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Payment Received: ₹0.00"
            android:textColor="#2D3748"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"
            tools2:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ledger_of_the_trip"
            android:textColor="#0D1A39"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="horizontal">

            <TableLayout
                android:id="@+id/table_trip_ledger"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:stretchColumns="*">

                <TableRow
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#F7FAFC"
                    android:paddingVertical="10dp"
                    tools:ignore="UselessParent">

                    <TextView
                        android:text="@string/sl_no"
                        android:textStyle="bold"
                        android:textColor="#0D1A39"
                        android:paddingHorizontal="8dp"
                        android:gravity="center"/>
                    <TextView
                        android:text="@string/description"
                        android:textStyle="bold"
                        android:textColor="#0D1A39"
                        android:paddingHorizontal="12dp"
                        android:gravity="left"
                        tools2:ignore="RtlHardcoded" />
                    <TextView
                        android:text="@string/date_of_ntransaction"
                        android:textStyle="bold"
                        android:textColor="#0D1A39"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"/>
                    <TextView
                        android:text="@string/expense_namount"
                        android:textStyle="bold"
                        android:textColor="#0D1A39"
                        android:paddingHorizontal="12dp"
                        android:gravity="right"
                        tools2:ignore="RtlHardcoded" />
                    <TextView
                        android:text="@string/payment_namount"
                        android:textStyle="bold"
                        android:textColor="#0D1A39"
                        android:paddingHorizontal="12dp"
                        android:gravity="right"
                        tools2:ignore="RtlHardcoded" />
                    <TextView
                        android:text="@string/expense_nfor"
                        android:textStyle="bold"
                        android:textColor="#0D1A39"
                        android:paddingHorizontal="12dp"
                        android:gravity="left"
                        tools2:ignore="RtlHardcoded" />
                    <TextView
                        android:text="@string/expense_by_nor_payment_by"
                        android:textStyle="bold"
                        android:textColor="#0D1A39"
                        android:paddingHorizontal="12dp"
                        android:gravity="left"
                        tools2:ignore="RtlHardcoded" />
                </TableRow>

            </TableLayout>
        </HorizontalScrollView>

    </LinearLayout>
</ScrollView>